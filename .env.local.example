# Microsoft Graph app-only (client-credentials) mail sending.
# Azure app registration needs the Mail.Send application permission (admin-consented),
# scoped to GRAPH_SENDER via an application access policy.

# Azure AD tenant ID the app registration lives in.
GRAPH_TENANT_ID=

# Azure app registration (application) client ID.
GRAPH_CLIENT_ID=

# Azure app registration client secret.
GRAPH_CLIENT_SECRET=

# HR mailbox the email is sent FROM (Graph /users/{GRAPH_SENDER}/sendMail).
GRAPH_SENDER=hr.geneva@payroll-and-outsourcing.com

# Mailbox the travel request email is sent TO.
HR_RECIPIENT=hr.geneva@payroll-and-outsourcing.com

# Vercel Blob store token, used by Travel Claim's supporting-document uploads. The browser
# uploads files directly to Blob (bypassing the ~4.5MB Vercel function body limit) via
# @vercel/blob/client; this token authorizes those client uploads server-side.
# Create a Blob store in the Vercel dashboard (Storage tab) and copy its token here --
# `vercel env pull` also fills this in automatically once the store is linked to the project.
BLOB_READ_WRITE_TOKEN=

# Azure Document Intelligence (Layout model) -- pre-submit scan of the Travel Cover PDF, see
# lib/travel/claim/document-scan. Optional: when either of these is unset, the app falls back to
# a stub provider (scanAvailable:false, "verify manually" note) so the rest of the claim flow
# still works without an Azure resource.
DOC_INTELLIGENCE_ENDPOINT=
DOC_INTELLIGENCE_KEY=
