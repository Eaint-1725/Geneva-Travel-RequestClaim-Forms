# Microsoft Graph app-only (client-credentials) mail sending.
# Azure app registration needs the Mail.Send application permission (admin-consented),
# scoped to GRAPH_SENDER via an application access policy.

# Azure AD tenant ID the app registration lives in.
GRAPH_TENANT_ID=

# Azure app registration (application) client ID.
GRAPH_CLIENT_ID=

# Azure app registration client secret.
GRAPH_CLIENT_SECRET=

# HR mailbox the email is sent FROM (Graph /users/{GRAPH_SENDER}/sendMail).
GRAPH_SENDER=hr.geneva@payroll-and-outsourcing.com

# Mailbox the travel request email is sent TO.
HR_RECIPIENT=hr.geneva@payroll-and-outsourcing.com

# Vercel Blob store token, used by Travel Claim's supporting-document uploads. The browser
# uploads files directly to Blob (bypassing the ~4.5MB Vercel function body limit) via
# @vercel/blob/client; this token authorizes those client uploads server-side.
# Create a Blob store in the Vercel dashboard (Storage tab) and copy its token here --
# `vercel env pull` also fills this in automatically once the store is linked to the project.
BLOB_READ_WRITE_TOKEN=

# Pre-submit scan of the Travel Cover and Travel Report PDFs, see lib/travel/claim/document-scan.
# Optional: when none of the below are set, the app falls back to a stub provider
# (scanAvailable:false, "verify manually" note) so the rest of the claim flow still works without
# a scan provider configured.
#
# Provider precedence (see document-scan/index.ts): SCAN_PROVIDER override if set, else OpenAI (if
# OPENAI_API_KEY is set), else Azure Document Intelligence (if both vars below are set), else stub.
SCAN_PROVIDER=

# OpenAI vision scan of the Travel Cover/Report PDFs (lib/travel/claim/document-scan/openai-provider.ts).
OPENAI_API_KEY=
# Optional -- defaults to "gpt-4o" (see DEFAULT_MODEL in openai-provider.ts) when unset.
OPENAI_SCAN_MODEL=

# Azure Document Intelligence (Layout model) -- alternative scan provider, used only when OpenAI
# isn't configured. Cover only -- it doesn't scan the Travel Report (see AzureDocScanProvider's
# scanTravelReport), so a Report scan always falls back to the manual-verify path under Azure.
DOC_INTELLIGENCE_ENDPOINT=
DOC_INTELLIGENCE_KEY=
